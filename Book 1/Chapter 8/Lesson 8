// Create the answer array of underscores
var answerArray = setupAnswerArray(word);
console.log(answerArray); // Show the underscores in the console

// Track how many letters are left to guess
var remainingLetters = word.length;

// Main game loop — runs until all letters are guessed
while (remainingLetters > 0) {
  showPlayerProgress(answerArray); // Show current progress

  var guess = getGuess(); // Get a guess from the player

  if (guess === null) {
    break; // Player clicked Cancel — exit the loop
  } else if (guess.length !== 1) {
    // NOTE: This check is redundant — getGuess() already validates this
    alert("Please enter a single letter.");
  } else {
    // Update the game state
    var correctGuesses = updateGameState(guess, word, answerArray);

    // NOTE: updateGameState() does not return anything,
    // so correctGuesses is undefined and this line breaks:
    remainingLetters -= correctGuesses;
  }
}

