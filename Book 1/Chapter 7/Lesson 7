// List of possible words for the game
var words = [
  "javascript",
  "monkey",
  "amazing",
  "pancake",
  "programmer",
  "elephant",
  "creative",
  "browswer",
];

// Pick a random word from the list
var word = words[Math.floor(Math.random() * words.length)];
console.log(word); // (For debugging) shows the chosen word in the console

// Create an array of underscores the same length as the word
var answerArray = [];
for (var i = 0; i < word.length; i++) {
  answerArray[i] = "_";
}

// Track how many letters still need to be guessed
var remainingLetters = word.length;

// Limit how many guesses the player can make
var maxGuesses = 10;
var guessesUsed = 0;

// Main game loop: runs while letters remain AND guesses are still available
while (remainingLetters > 0 && guessesUsed < maxGuesses) {
  // Show the current progress (e.g., "_ _ a _ _")
  alert(answerArray.join(" "));

  // Ask the player for a letter
  var guess = prompt("Guess a letter, or click Cancel to stop playing.");

  // Convert guess to lowercase so uppercase doesn't break the game
  guess = guess.toLowerCase();

  // If the player clicks Cancel, exit the loop
  if (guess === null) {
    break;

  // Validate input: must be exactly one letter a–z
  } else if (guess.length !== 1 || !guess.match(/[a-z]/)) {
    alert("Please enter a single letter.");

  } else {
    // Loop through the word to check if the guessed letter appears
    for (var j = 0; j < word.length; j++) {
      if (word[j] === guess) {
        // Replace the underscore with the correctly guessed letter
        answerArray[j] = guess;
        remainingLetters--; // One fewer letter left to guess
      }
    }

    // Count this as a used guess (even if it was wrong)
    guessesUsed++;
  }
}

// Show the final result
alert(answerArray.join(" "));
alert("Good job! The answer was " + word);
