// --- EVENT LISTENER: RIGHT EYE ---

// Grab the right eye element
var rightEye = document.getElementById("righteye");
console.log(rightEye); // Log it to confirm it exists

// When the right eye is clicked, run moveUpDown()
rightEye.addEventListener("click", moveUpDown);


// Function to move a clicked part up and down
function moveUpDown(e) {
  var robotPart = e.target; // The element that was clicked
  var top = 0;              // Starting top position

  // Run the frame() function every 50ms
  var id = setInterval(frame, 50);

  function frame () {
    robotPart.style.top = top + "%"; // Move the part down
    top++;

    // Stop animation when it reaches 20%
    if (top === 20) {
      clearInterval(id);
    }
  }
}


// --- EVENT LISTENER: LEFT EYE ---

// Grab the left eye and attach the same moveUpDown animation
var leftEye = document.getElementById("lefteye");
leftEye.addEventListener("click", moveUpDown);


// --- EVENT LISTENER: LEFT ARM ---

// Grab the left arm and attach a left-right animation
var leftArm = document.getElementById("leftarm");
leftArm.addEventListener("click", moveRightLeft);


// Function to move a clicked part left and right
function moveRightLeft(e) {
  var robotPart = e.target; // The element that was clicked
  var left = 0;             // Starting left position

  var id = setInterval(frame, 50);

  function frame () {
    robotPart.style.left = left + "%"; // Move the part to the right
    left++;

    // Stop animation when it reaches 70%
    if (left === 70) {
      clearInterval(id);
    }
  }
}

// --- EVENT LISTENER: NOSE ---

// Grab the nose and attach a wiggle animation
var nose = document.getElementById("nose");
nose.addEventListener("click", wiggleUpDown);


// Function to wiggle the nose slightly up and down
function wiggleUpDown(e) {
  var robotPart = e.target; // The element that was clicked
  var top = 30;             // Starting top position

  var id = setInterval(frame, 50);

  function frame () {
    robotPart.style.top = top + "%"; // Move the nose down
    top++;

    // Stop animation when it reaches 40%
    if (top === 40) {
      clearInterval(id);
    }
  }
}
